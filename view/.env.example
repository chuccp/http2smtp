# HTTP2SMTP 环境配置模板
# ==========================================
# 端口说明：
# - 管理端口 (12566): Web UI 管理界面 + 管理 API (需要登录认证)
# - API 端口 (12567): 公共邮件发送 API (使用 Token 认证)
# ==========================================

# 管理 API 地址 - 用于登录、配置 SMTP、管理 Token 等 (端口 12566)
NEXT_PUBLIC_API_URL=http://localhost:12566

# 邮件发送 API 地址 - 用于实际发送邮件 (端口 12567)
NEXT_PUBLIC_SENDMAIL_API_URL=http://localhost:12567
